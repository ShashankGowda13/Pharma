# Copy to .env and set your values
PORT=5000

# Full connection string (Atlas or local), OR leave empty and use MONGO_ATLAS_* below / in-memory dev
MONGO_URI=

# Atlas without pasting full URI: hostname from Atlas → Connect → Drivers (e.g. cluster0.xxxxx.mongodb.net)
MONGO_ATLAS_HOST=
MONGO_ATLAS_USER=
MONGO_ATLAS_PASSWORD=
MONGO_ATLAS_DB=pharma_ecommerce

JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_EXPIRES_IN=7d
AUTO_SEED=true
